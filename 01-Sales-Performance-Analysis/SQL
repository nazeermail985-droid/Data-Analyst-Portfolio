-- Total Sales

SELECT
SUM(Sales) AS TotalSales
FROM Orders;

-- Total Profit

SELECT
SUM(Profit) AS TotalProfit
FROM Orders;

-- Total Orders

SELECT
COUNT(OrderID) AS TotalOrders
FROM Orders;

-- Sales by Region

SELECT
Region,
SUM(Sales) AS TotalSales
FROM Orders
GROUP BY Region
ORDER BY TotalSales DESC;

-- Top 10 Products

SELECT TOP 10
ProductName,
SUM(Sales) AS Sales
FROM Orders
GROUP BY ProductName
ORDER BY Sales DESC;

-- Monthly Sales

SELECT
YEAR(OrderDate) AS Year,
MONTH(OrderDate) AS Month,
SUM(Sales) AS Sales
FROM Orders
GROUP BY YEAR(OrderDate), MONTH(OrderDate)
ORDER BY Year, Month;

-- Category Sales

SELECT
Category,
SUM(Sales) AS Sales,
SUM(Profit) AS Profit
FROM Orders
GROUP BY Category;

-- Top Customers

SELECT TOP 10
CustomerName,
SUM(Sales) AS Sales
FROM Orders
GROUP BY CustomerName
ORDER BY Sales DESC;
